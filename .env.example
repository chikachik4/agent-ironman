# ── 실행 환경 ──────────────────────────────────────────
ENVIRONMENT=prod                      # test | prod

# ── VPC Private IP ─────────────────────────────────────
VPC1_INSTANCE_PRIVATE_IP=10.0.x.x    # VPC1 Prometheus/K3s 인스턴스
VPC3_INSTANCE_PRIVATE_IP=10.2.x.x    # 현재 인스턴스(VPC3 ArgoCD)

# ── AWS ────────────────────────────────────────────────
AWS_REGION=ap-northeast-2

# IAM Role 사용 시 아래 두 항목 불필요 (EC2 인스턴스 프로파일로 자동 인증)
# 액세스 키 방식으로 전환할 경우 아래 주석 해제
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...

# ── Redis ──────────────────────────────────────────────
REDIS_HOST=localhost                  # ElastiCache 사용 시 클러스터 엔드포인트로 변경
REDIS_PORT=6379

# ── OpenSearch ─────────────────────────────────────────
OPENSEARCH_URL=https://xxxx.ap-northeast-2.es.amazonaws.com

# ── Kubernetes (prod 환경) ──────────────────────────────
EKS_CLUSTER_ENDPOINT=https://xxxx.gr7.ap-northeast-2.eks.amazonaws.com
VPC1_PROMETHEUS_IP=10.0.x.x          # VPC1 Prometheus 쿼리 대상 IP

# ── VPC2 온프레미스 (미연동 시 생략 가능) ───────────────
# VPC2_K8S_ENDPOINT=https://10.1.x.x:6443
# VPC2_PROMETHEUS_IP=10.1.x.x

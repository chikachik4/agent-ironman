# ── 실행 환경 ──────────────────────────────────────────
ENVIRONMENT=prod                      # test | prod

# ── VPC Private IP ─────────────────────────────────────
VPC1_INSTANCE_PRIVATE_IP=10.0.x.x    # VPC1 K8s(EKS) 인스턴스
VPC3_INSTANCE_PRIVATE_IP=10.2.x.x    # VPC3 ArgoCD/Management Hub 인스턴스

# ── AWS ────────────────────────────────────────────────
AWS_REGION=ap-northeast-2

# IAM Role 사용 시 아래 두 항목 불필요 (EC2 인스턴스 프로파일로 자동 인증)
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...

# ── Redis ──────────────────────────────────────────────
REDIS_HOST=localhost                  # ElastiCache 사용 시 클러스터 엔드포인트로 변경
REDIS_PORT=6379

# ── OpenSearch ─────────────────────────────────────────
OPENSEARCH_URL=https://xxxx.ap-northeast-2.es.amazonaws.com

# ── VPC3 중앙 Prometheus ────────────────────────────────
# VPC1·VPC2 Prometheus가 Remote Write로 메트릭을 전송하는 집중 수집 지점
# 미설정 시 VPC3_INSTANCE_PRIVATE_IP:9090 자동 사용
# VPC3_PROMETHEUS_URL=http://10.2.x.x:9090

# ── Kubernetes (prod 환경) ──────────────────────────────
EKS_CLUSTER_ENDPOINT=https://xxxx.gr7.ap-northeast-2.eks.amazonaws.com
EKS_CLUSTER_NAME=bookjjeok-test-eks-cluster

# ── VPC2 온프레미스 (미연동 시 생략 가능) ───────────────
# VPC2_K8S_ENDPOINT=https://10.1.x.x:6443
